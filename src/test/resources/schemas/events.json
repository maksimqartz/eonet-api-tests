{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["title", "description", "link", "events"],
  "properties": {
    "title":       { "type": "string" },
    "description": { "type": "string" },
    "link":        { "type": "string", "format": "uri" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "categories", "geometry"],
        "properties": {
          "id":          { "type": "string" },
          "title":       { "type": "string" },
          "description": { "type": ["string", "null"] },
          "link":        { "type": "string", "format": "uri" },
          "closed":      { "type": ["string", "null"] },
          "categories":  { "type": "array", "minItems": 1 },
          "geometry":    { "type": "array", "minItems": 1 },
          "sources":     { "type": "array" }
        }
      }
    }
  }
}
