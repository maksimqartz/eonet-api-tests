{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["title", "description", "link", "magnitudes"],
  "properties": {
    "title":       { "type": "string" },
    "description": { "type": "string" },
    "link":        { "type": "string", "format": "uri" },
    "magnitudes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "unit", "description", "link"],
        "properties": {
          "id":          { "type": "string" },
          "name":        { "type": "string" },
          "unit":        { "type": "string" },
          "description": { "type": ["string", "null"] },
          "link":        { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
